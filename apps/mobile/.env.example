# Web chạy trên chính máy tính
EXPO_PUBLIC_API_URL_WEB=http://localhost:5001/api

# Android thật: thay YOUR_PC_LAN_IP bằng IPv4 của máy chạy backend.
# Ví dụ: http://192.168.1.10:5001/api
EXPO_PUBLIC_API_URL_ANDROID=http://YOUR_PC_LAN_IP:5001/api

# Android Emulator có thể dùng:
# EXPO_PUBLIC_API_URL_ANDROID=http://10.0.2.2:5001/api
